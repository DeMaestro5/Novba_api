// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum PaymentTerms {
  NET_15
  NET_30
  NET_60
  DUE_ON_RECEIPT
}

enum SubscriptionTier {
  FREE
  PRO
  STUDIO
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  DECLINED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
  TRIALING
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  PARTIALLY_PAID
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
  CASH
  CHECK
  MOBILE_MONEY
  CRYPTO
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ExpenseCategory {
  OFFICE_SUPPLIES
  TRAVEL
  MEALS
  UTILITIES
  SOFTWARE
  EQUIPMENT
  MARKETING
  PROFESSIONAL_SERVICES
  RENT
  INSURANCE
  TAXES
  OTHER
}

enum EmailType {
  INVOICE_SENT
  REMINDER
  PAYMENT_RECEIVED
  VERIFICATION
  PASSWORD_RESET
  WELCOME
  PROPOSAL_SENT 
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
}

// ============================================
// AUTHENTICATION & AUTHORIZATION
// ============================================

model Role {
  id        String   @id @default(uuid())
  code      String   @unique
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserRole[]

  @@map("roles")
}

model User {
  id             String    @id @default(uuid())
  
  email          String    @unique
  password       String?
  verified       Boolean   @default(false)
  status         Boolean   @default(true)
  
  name           String?
  firstName      String?
  lastName       String?
  profilePicUrl  String?
  phone          String?
  
  businessName   String?
  logoUrl        String?
  address        Json?
  website        String?
  taxId          String?
  
  defaultCurrency      String        @default("USD")
  defaultPaymentTerms  PaymentTerms  @default(NET_30)
  defaultTaxRate       Decimal       @default(0) @db.Decimal(5, 2)
  
  stripeAccountId   String?
  stripeCustomerId  String?
  
  emailVerificationToken String?
  emailVerificationTokenExpires DateTime?
  
  passwordResetToken   String?
  passwordResetExpires DateTime?
  
  subscriptionTier   SubscriptionTier   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  trialEndsAt        DateTime?
  
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)
  
  averageHourlyRate Decimal? @db.Decimal(10, 2)
  industry          String?
  experienceLevel   String?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime? 
  
  roles          UserRole[]
  keystores      Keystore[]
  clients        Client[]
  proposals      Proposal[]
  invoices       Invoice[]
  expenses       Expense[]
  payments       Payment[]
  emailLogs      EmailLog[]
  subscriptions  Subscription[]
  
  @@index([email])
  @@index([stripeCustomerId])
  @@index([subscriptionTier, subscriptionStatus])
  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Keystore {
  id           String   @id @default(uuid())
  userId       String
  primaryKey   String
  secondaryKey String
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([userId, primaryKey, status])
  @@map("keystores")
}

model ApiKey {
  id          String   @id @default(uuid())
  key         String   @unique
  version     Int
  permissions String[]
  comments    String[]
  status      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([key, status])
  @@map("api_keys")
}

// ============================================
// CLIENT MANAGEMENT
// ============================================

model Client {
  id             String       @id @default(uuid())
  userId         String
  
  companyName    String
  contactName    String?
  email          String?
  phone          String?
  billingAddress Json?
  paymentTerms   PaymentTerms @default(NET_30)
  currency       String       @default("USD")
  notes          String?      @db.Text
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  proposals      Proposal[]
  
  @@index([userId])
  @@index([userId, email])
  @@map("clients")
}

// ============================================
// INVOICE MANAGEMENT
// ============================================

model Invoice {
  id             String        @id @default(uuid())
  userId         String
  clientId       String
  
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  
  issueDate      DateTime      @db.Date
  dueDate        DateTime      @db.Date
  
  subtotal       Decimal       @db.Decimal(10, 2)
  taxRate        Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  
  notes          String?       @db.Text
  terms          String?       @db.Text
  pdfUrl         String?
  
  sentAt              DateTime?
  paidAt              DateTime?
  lastReminderSentAt  DateTime?
  reminderCount       Int       @default(0)
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  client         Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lineItems      InvoiceLineItem[]
  payments       Payment[]
  emailLogs      EmailLog[]
  
  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([clientId])
  @@index([userId, status])
  @@index([status, dueDate])
  @@map("invoices")
}

// ============================================
// PROPOSAL SYSTEM
// ============================================

model Proposal {
  id             String         @id @default(uuid())
  userId         String
  clientId       String
  
  proposalNumber String
  title          String
  status         ProposalStatus @default(DRAFT)
  
  scope          String?        @db.Text
  deliverables   Json?
  timeline       Json?
  terms          String?        @db.Text
  
  totalAmount    Decimal        @db.Decimal(10, 2)
  currency       String         @default("USD")
  
  validUntil     DateTime?
  sentAt         DateTime?
  viewedAt       DateTime?
  respondedAt    DateTime?
  
  pdfUrl         String?
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lineItems      ProposalLineItem[]
  
  @@unique([userId, proposalNumber])
  @@index([userId])
  @@index([clientId])
  @@index([userId, status])
  @@map("proposals")
}

model ProposalLineItem {
  id          String   @id @default(uuid())
  proposalId  String
  
  description String   @db.Text
  quantity    Decimal  @db.Decimal(10, 2)
  rate        Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  order       Int
  
  createdAt   DateTime @default(now())
  
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  
  @@index([proposalId])
  @@map("proposal_line_items")
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  
  description String   @db.Text
  quantity    Decimal  @db.Decimal(10, 2)
  rate        Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  order       Int
  
  createdAt   DateTime @default(now())
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  @@index([invoiceId])
  @@map("invoice_line_items")
}

// ============================================
// EXPENSE TRACKING
// ============================================

model Expense {
  id             String          @id @default(uuid())
  userId         String
  
  date           DateTime        @db.Date
  vendor         String
  amount         Decimal         @db.Decimal(10, 2)
  currency       String          @default("USD")
  category       ExpenseCategory
  description    String?         @db.Text
  taxDeductible  Boolean         @default(false)
  receiptUrl     String?
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@map("expenses")
}

// ============================================
// PAYMENT TRACKING
// ============================================

model Payment {
  id                    String        @id @default(uuid())
  invoiceId             String
  userId                String
  
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("USD")
  paymentMethod         PaymentMethod
  stripePaymentIntentId String?
  status                PaymentStatus @default(PENDING)
  
  paidAt                DateTime?
  notes                 String?       @db.Text
  
  createdAt             DateTime      @default(now())
  
  invoice               Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([invoiceId])
  @@index([userId])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

// ============================================
// EMAIL LOGGING
// ============================================

model EmailLog {
  id         String      @id @default(uuid())
  userId     String
  invoiceId  String?
  
  type       EmailType
  recipient  String
  subject    String
  status     EmailStatus @default(QUEUED)
  
  sentAt     DateTime?
  error      String?     @db.Text
  
  createdAt  DateTime    @default(now())
  
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice    Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([invoiceId])
  @@index([type])
  @@index([status])
  @@map("email_logs")
}

// ============================================
// SUBSCRIPTION MANAGEMENT
// ============================================

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  
  stripeSubscriptionId String             @unique
  tier                 SubscriptionTier
  status               SubscriptionStatus
  
  currentPeriodStart   DateTime           @db.Date
  currentPeriodEnd     DateTime           @db.Date
  cancelAtPeriodEnd    Boolean            @default(false)
  
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}
